<Application x:Class="Sinp.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Snipaste 风格深色主题 -->
        <SolidColorBrush x:Key="BgDark" Color="#1E1E2E"/>
        <SolidColorBrush x:Key="BgPanel" Color="#2A2A3C"/>
        <SolidColorBrush x:Key="FgText" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="Accent" Color="#4FC3F7"/>
        <SolidColorBrush x:Key="AccentDim" Color="#2A7A9F"/>
        <SolidColorBrush x:Key="BorderSubtle" Color="#3A3A4C"/>
    </Application.Resources>
</Application>
