<Window x:Class="Sinp.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sinp - 截图OCR"
        Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#1E1E2E"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        ShowActivated="True"
        Visibility="Visible"
        Topmost="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="Background" Value="#2A2A3C"/>
            <Setter Property="Foreground" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4FC3F7"/>
                                <Setter Property="Foreground" Value="#111"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主容器（深色主题） -->
    <Border Background="#1E1E2E"
            BorderBrush="#3A3A4C"
            BorderThickness="1"
            CornerRadius="10"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Color="#000"/>
        </Border.Effect>

        <DockPanel>

            <!-- 标题栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#2A2A3C"
                    CornerRadius="10,10,0,0"
                    Height="40"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="Sinp 截图OCR"
                               Foreground="#E0E0E0"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="14,0,0,0"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,8,0">
                        <Button Content="—"
                                Width="36" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#AAA"
                                Click="BtnMinimize_Click"
                                Style="{StaticResource FlatBtn}"/>
                        <Button Content="✕"
                                Width="36" Height="28"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#F44"
                                Click="BtnClose_Click"
                                Style="{StaticResource FlatBtn}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 工具栏 -->
            <Border DockPanel.Dock="Top"
                    Background="#252538"
                    Padding="10,8">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <Button x:Name="BtnCapture"
                            Content="📸 截图"
                            Style="{StaticResource ToolBtn}"
                            Click="BtnCapture_Click"/>
                    <Button x:Name="BtnLongCapture"
                            Content="📜 长截图"
                            Style="{StaticResource ToolBtn}"
                            Click="BtnLongCapture_Click"/>
                    <Separator Width="1"
                               Background="#3A3A4C"
                               Margin="8,0"/>
                    <Button x:Name="BtnOCR"
                            Content="🔍 OCR"
                            Style="{StaticResource ToolBtn}"
                            Click="BtnOCR_Click"/>
                    <Button x:Name="BtnPin"
                            Content="📌 固定"
                            Style="{StaticResource ToolBtn}"
                            Click="BtnPin_Click"/>
                </StackPanel>
            </Border>

            <!-- 状态栏 -->
            <Border DockPanel.Dock="Bottom"
                    Background="#1A1A2A"
                    Padding="10,6">
                <TextBlock x:Name="StatusText"
                           Text="就绪 | Ctrl+Shift+S 截图 | ESC 取消"
                           Foreground="#777"
                           FontSize="11"/>
            </Border>

            <!-- 结果面板 -->
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 结果操作栏 -->
                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            Margin="0,0,0,8">
                    <TextBlock Text="📋 识别结果"
                               Foreground="#AAA"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button Content="复制全部"
                            Margin="12,0,0,0"
                            Style="{StaticResource SmallBtn}"
                            Click="BtnCopyAll_Click"/>
                    <Button Content="导出 TXT"
                            Margin="6,0,0,0"
                            Style="{StaticResource SmallBtn}"
                            Click="BtnExport_Click"/>
                </StackPanel>

                <!-- 文本结果 -->
                <Border Grid.Row="1"
                        Background="#16161E"
                        BorderBrush="#2A2A3C"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ResultText"
                                   Text="（截图后自动显示 OCR 结果）"
                                   Foreground="#888"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   LineHeight="22"/>
                    </ScrollViewer>
                </Border>
            </Grid>

        </DockPanel>
    </Border>
</Window>
